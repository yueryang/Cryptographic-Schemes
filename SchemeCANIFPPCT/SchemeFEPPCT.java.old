    public void set_mpk(Field<Element> G1, Field<Element> G2, Field<Element> GT, Element e, Element g1, Element g2, Element p, Element g3, Element H1, Element H2, Element H3, Element H4, Element R, Element S, Element T, Element Omega, Element v1, Element v2, Element v3, Element v4)
    {
    	this.mpk = new MPK(G1, G2, GT, e, g1,  g2, p, g3, H1, H2, H3, H4, R, S, T, Omega, v1, v2, v3, v4);
    }
    
